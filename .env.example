# Copy this file to .env and fill in all values before running docker compose up

# ── Spotify OAuth App ──────────────────────────────────────────────────────────
# Create at https://developer.spotify.com/dashboard → "Create app"
# Set Redirect URI to: http://127.0.0.1:8000/api/music/spotify/callback
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/api/music/spotify/callback

# ── Google OAuth for YouTube Music ────────────────────────────────────────────
# Create at https://console.cloud.google.com → APIs & Services → Credentials
# Enable "YouTube Data API v3", create OAuth2 Client ID (Web application)
# Set Authorized redirect URI to: http://localhost/api/auth/ytmusic/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
YTMUSIC_REDIRECT_URI=http://localhost/api/auth/ytmusic/callback

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# Random string used to sign OAuth state cookies (any long random string)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/musicsync
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=musicsync

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Sync Settings ─────────────────────────────────────────────────────────────
# Minimum rapidfuzz WRatio score (0–100) to accept a fuzzy track match
TRACK_MATCH_THRESHOLD=85

# ── Celery Worker ─────────────────────────────────────────────────────────────
# Number of concurrent worker processes (default: 4)
CELERY_CONCURRENCY=4
